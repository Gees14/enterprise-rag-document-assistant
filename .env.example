# Enterprise RAG Document Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME="Enterprise RAG Document Assistant"
APP_VERSION="1.0.0"
DEBUG=false

# ─────────────────────────────────────────────
# Storage paths (relative to backend/)
# ─────────────────────────────────────────────
UPLOAD_DIR=data/uploads
VECTOR_STORE_DIR=data/vector_store
EVAL_DIR=data/eval

# ─────────────────────────────────────────────
# Embeddings
# Options: all-MiniLM-L6-v2 (384d), all-mpnet-base-v2 (768d)
# ─────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ─────────────────────────────────────────────
# Chunking
# ─────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─────────────────────────────────────────────
# Retrieval
# ─────────────────────────────────────────────
DEFAULT_TOP_K=5
MIN_SIMILARITY_SCORE=0.0

# ─────────────────────────────────────────────
# LLM Generation (optional)
# If OPENAI_API_KEY is empty, the system runs in retrieval-only mode.
# Supports any OpenAI-compatible API (OpenAI, Azure OpenAI, Groq, Ollama, etc.)
# ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2

# ─────────────────────────────────────────────
# ChromaDB
# ─────────────────────────────────────────────
CHROMA_COLLECTION_NAME=rag_documents

# ─────────────────────────────────────────────
# CORS (comma-separated origins)
# ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
